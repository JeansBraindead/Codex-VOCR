# Copy to .env and set real local values only.
# Do not commit secrets.
OPENAI_API_KEY=
OPENAI_MODEL=
# Optional for LM Studio, llama.cpp, vLLM, or another OpenAI-compatible local server.
# Example: http://localhost:1234/v1
OPENAI_BASE_URL=
LMSTUDIO_API_KEY=
VOCR_HOME=.vocr
VOCR_CODEX_PROFILE=safe
VOCR_CODEX_COMMAND=
VOCR_CODEX_UNSANDBOXED=false
VOCR_GRAPH_MAX_FILE_BYTES=200000
